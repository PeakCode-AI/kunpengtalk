---
import { Image } from 'astro:assets';
import SectionHead from './SectionHead.astro';
import { profile, site } from '../data/site';

import poseFront from '../assets/crops/pose-front.png';
import exprKaixin from '../assets/crops/expr-kaixin.png';
import exprSikao from '../assets/crops/expr-sikao.png';
import exprJingya from '../assets/crops/expr-jingya.png';
import exprDianzan from '../assets/crops/expr-dianzan.png';
import exprRenzhen from '../assets/crops/expr-renzhen.png';
import exprGaoding from '../assets/crops/expr-gaoding.png';
import actLaptop from '../assets/crops/act-laptop.png';
import actCamera from '../assets/crops/act-camera.png';
import actIdea from '../assets/crops/act-idea.png';

const expressions = [
  { src: exprKaixin, label: '开心' },
  { src: exprSikao, label: '思考' },
  { src: exprJingya, label: '惊讶' },
  { src: exprDianzan, label: '点赞' },
  { src: exprRenzhen, label: '认真' },
  { src: exprGaoding, label: '搞定' },
];

const actions = [
  { src: actLaptop, label: 'AI 讲解中', en: 'VIBE CODING' },
  { src: actCamera, label: '拍摄现场', en: 'ON SET' },
  { src: actIdea, label: '灵感时刻', en: 'IDEA TIME' },
];
---

<section id="about">
  <div class="container">
    <SectionHead
      index="03 / 关于我们"
      title="一个探索者的<br />AI 实验田"
      desc="鲲鹏Talk 不是机构号，而是一个真实的人在认真地折腾 AI。"
    />

    <div class="about-grid">
      <div class="story" data-reveal>
        <p class="intro">{profile.intro}</p>

        <ul class="values">
          {profile.values.map((v, i) => (
            <li>
              <span class="vno">0{i + 1}</span>
              {v}
            </li>
          ))}
        </ul>

        <blockquote>
          “{site.motto}。”
        </blockquote>

        <dl class="facts">
          {profile.facts.map((f) => (
            <div class="fact">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <figure class="standee" data-reveal style="--d:.15s">
        <div class="standee-img">
          <Image src={poseFront} alt="鲲鹏Talk 标准形象" width={300} format="webp" />
        </div>
        <figcaption>标准形象 · 鲲鹏</figcaption>
      </figure>
    </div>

    <div class="gallery" data-reveal>
      <div class="group">
        <h3 class="group-title">表情包 <span>STICKERS</span></h3>
        <ul class="expr-row">
          {expressions.map((e) => (
            <li>
              <span class="expr-img">
                <Image src={e.src} alt={`鲲鹏Talk 表情包 · ${e.label}`} width={140} format="webp" />
              </span>
              <span class="expr-label">{e.label}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="group">
        <h3 class="group-title">动作展示 <span>ACTION POSES</span></h3>
        <ul class="act-row">
          {actions.map((a) => (
            <li class="act-card">
              <div class="act-img">
                <Image src={a.src} alt={`鲲鹏Talk · ${a.label}`} width={260} format="webp" />
              </div>
              <div class="act-meta">
                <strong>{a.label}</strong>
                <span>{a.en}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .intro {
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 2;
    color: var(--fg);
  }

  .values {
    margin: 40px 0;
    border-top: 1px solid var(--line);
  }

  .values li {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
    font-size: clamp(17px, 1.6vw, 20px);
    font-weight: 600;
    transition: padding-left 0.3s;
  }

  .values li:hover {
    padding-left: 8px;
  }

  .vno {
    font-size: 13px;
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px var(--faint);
  }

  blockquote {
    margin: 0 0 40px;
    padding: 28px 32px;
    border-left: 3px solid;
    border-image: linear-gradient(180deg, #2e8bff, #1fdec2) 1;
    background: rgba(46, 139, 255, 0.06);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: clamp(19px, 2vw, 24px);
    font-weight: 700;
    line-height: 1.6;
  }

  .facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .fact {
    background: var(--panel);
    padding: 22px 24px;
  }

  .fact dt {
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--faint);
    margin-bottom: 8px;
  }

  .fact dd {
    font-size: 15px;
    line-height: 1.7;
  }

  /* ---- 站姿形象卡 ---- */
  .standee {
    position: sticky;
    top: calc(var(--nav-h) + 24px);
    max-width: 380px;
    margin-inline: auto;
    padding: 14px;
    border-radius: calc(var(--radius) + 10px);
    background: linear-gradient(160deg, rgba(46, 139, 255, 0.4), rgba(31, 222, 194, 0.18) 55%, rgba(31, 222, 194, 0.05));
    box-shadow: 0 30px 80px rgba(46, 139, 255, 0.15);
  }

  .standee-img {
    border-radius: calc(var(--radius) + 2px);
    overflow: hidden;
    background: #f5f7fa;
  }

  .standee-img img {
    width: 100%;
    height: auto;
  }

  .standee figcaption {
    padding: 14px 6px 6px;
    text-align: center;
    font-size: 13px;
    letter-spacing: 0.1em;
    color: rgba(4, 18, 26, 0.85);
    font-weight: 600;
  }

  /* ---- IP 画廊 ---- */
  .gallery {
    margin-top: clamp(64px, 8vw, 100px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 64px);
  }

  .group-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 28px;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .group-title span {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--faint);
  }

  .expr-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .expr-row li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .expr-img {
    width: clamp(84px, 9vw, 108px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    background: #f5f7fa;
    border: 1px solid var(--line-strong);
    transition:
      transform 0.35s cubic-bezier(0.2, 0.6, 0.2, 1),
      box-shadow 0.35s;
  }

  .expr-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .expr-row li:hover .expr-img {
    transform: translateY(-6px) rotate(-3deg);
    box-shadow: 0 14px 36px rgba(31, 222, 194, 0.25);
  }

  .expr-label {
    font-size: 13px;
    color: var(--muted);
  }

  .act-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .act-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    overflow: hidden;
    transition:
      transform 0.35s cubic-bezier(0.2, 0.6, 0.2, 1),
      border-color 0.35s;
  }

  .act-card:hover {
    transform: translateY(-5px);
    border-color: var(--line-strong);
  }

  .act-img {
    background: #f5f7fa;
    overflow: hidden;
  }

  .act-img img {
    width: 100%;
    height: auto;
    transition: transform 0.5s cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .act-card:hover .act-img img {
    transform: scale(1.05);
  }

  .act-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 14px 16px;
  }

  .act-meta strong {
    font-size: 14px;
  }

  .act-meta span {
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--faint);
  }

  @media (max-width: 900px) {
    .about-grid,
    .gallery {
      grid-template-columns: 1fr;
    }

    .standee {
      position: static;
      max-width: 300px;
    }
  }

  @media (max-width: 560px) {
    .act-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .act-meta {
      padding: 10px 12px;
    }
  }
</style>
