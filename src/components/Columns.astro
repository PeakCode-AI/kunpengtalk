---
import SectionHead from './SectionHead.astro';
import { columns } from '../data/site';
---

<section id="content">
  <div class="container">
    <SectionHead
      index="01 / 内容专栏"
      title="我们讲什么"
      desc="五个固定专栏，覆盖从「看懂模型」到「用好模型」的完整链路。"
    />

    <div class="grid">
      {columns.map((c, i) => (
        <article class={`card card-${i}`} data-reveal style={`--d:${i * 0.08}s`}>
          <div class="top">
            <span class="no">{c.no}</span>
            <span class="en">{c.en}</span>
          </div>
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
          <ul class="tags">
            {c.tags.map((t) => <li>{t}</li>)}
          </ul>
          <span class="arrow" aria-hidden="true">→</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }

  .card {
    position: relative;
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    min-height: 300px;
    padding: 32px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(170deg, var(--panel) 0%, rgba(12, 17, 27, 0.4) 100%);
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1),
      border-color 0.4s;
  }

  /* 前两张卡片更宽，形成节奏感 */
  .card-0,
  .card-1 {
    grid-column: span 3;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(420px 220px at 85% -10%, rgba(46, 139, 255, 0.14), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
  }

  .card:hover::before {
    opacity: 1;
  }

  .top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: auto;
  }

  .no {
    font-size: 44px;
    font-weight: 700;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(148, 163, 184, 0.45);
    transition: -webkit-text-stroke-color 0.4s;
  }

  .card:hover .no {
    -webkit-text-stroke-color: var(--cyan);
  }

  .en {
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--faint);
  }

  h3 {
    font-size: clamp(22px, 2.2vw, 28px);
    font-weight: 700;
    margin: 36px 0 12px;
  }

  p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.8;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }

  .tags li {
    font-size: 12px;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
  }

  .arrow {
    position: absolute;
    top: 28px;
    right: 28px;
    font-size: 20px;
    color: var(--cyan);
    opacity: 0;
    transform: translate(-8px, 8px);
    transition:
      opacity 0.35s,
      transform 0.35s;
  }

  .card:hover .arrow {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 960px) {
    .card,
    .card-0,
    .card-1 {
      grid-column: span 3;
    }
  }

  @media (max-width: 640px) {
    .card,
    .card-0,
    .card-1 {
      grid-column: span 6;
      min-height: 0;
    }
  }
</style>
