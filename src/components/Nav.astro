---
import { site } from '../data/site';

const path = Astro.url.pathname;
const base = path === '/' ? '' : '/';

const links = [
  { label: '首页', href: '/' },
  { label: '产品服务', href: '/products' },
  { label: '咨询服务', href: '/services' },
  { label: '课程', href: '/courses' },
  { label: '视频定制', href: '/video' },
  { label: '开源项目', href: '/opensource' },
];

const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={site.name}>
      <svg class="mark" viewBox="0 0 64 64" aria-hidden="true">
        <defs>
          <linearGradient id="nav-g" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#2e8bff"></stop>
            <stop offset="1" stop-color="#1fdec2"></stop>
          </linearGradient>
        </defs>
        <rect width="64" height="64" rx="16" fill="url(#nav-g)"></rect>
        <text x="32" y="45" font-size="34" font-weight="700" fill="#04121a" text-anchor="middle" font-family="system-ui,'PingFang SC',sans-serif">鲲</text>
      </svg>
      <span class="wordmark">鲲鹏<em>Talk</em></span>
    </a>

    <nav class="nav-links" aria-label="主导航">
      {links.map((l) => <a href={l.href} class={isActive(l.href) ? 'active' : undefined}>{l.label}</a>)}
      <a href={`${base}#contact`} class="btn btn-primary nav-cta">商务合作</a>
    </nav>

    <button class="nav-toggle" aria-label="打开菜单">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 90;
    height: var(--nav-h);
    transition:
      background 0.35s,
      border-color 0.35s,
      backdrop-filter 0.35s;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: rgba(5, 7, 12, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--line);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.01em;
  }

  .brand .mark {
    width: 36px;
    height: 36px;
    border-radius: 10px;
  }

  .wordmark em {
    font-style: normal;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 34px;
  }

  .nav-links > a:not(.btn) {
    font-size: 15px;
    color: var(--muted);
    transition: color 0.25s;
    position: relative;
  }

  .nav-links > a:not(.btn):hover {
    color: var(--fg);
  }

  .nav-links > a.active {
    color: var(--fg);
  }

  .nav-links > a.active::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -8px;
    transform: translateX(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--grad);
  }

  .nav-cta {
    padding: 10px 22px;
    font-size: 14px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--fg);
    transition: transform 0.3s;
  }

  @media (max-width: 860px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: var(--nav-h);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      padding: 20px 5vw 32px;
      background: rgba(5, 7, 12, 0.96);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--line);
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition:
        opacity 0.3s,
        transform 0.3s;
    }

    .nav-links > a:not(.btn) {
      font-size: 20px;
      padding: 12px 0;
    }

    .nav-cta {
      margin-top: 16px;
    }

    :global(body.menu-open) .nav-links {
      transform: none;
      opacity: 1;
      pointer-events: auto;
    }

    :global(body.menu-open) .nav-toggle span:first-child {
      transform: translateY(4px) rotate(45deg);
    }

    :global(body.menu-open) .nav-toggle span:last-child {
      transform: translateY(-4px) rotate(-45deg);
    }
  }
</style>
