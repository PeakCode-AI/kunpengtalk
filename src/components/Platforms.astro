---
import SectionHead from './SectionHead.astro';
import { platforms } from '../data/site';

const icons: Record<string, string> = {
  // 哔哩哔哩：小电视
  bilibili:
    '<path d="M8 7 5 4M16 7l3-3"/><rect x="3" y="7" width="18" height="13" rx="4"/><circle cx="9" cy="13" r="0.6" fill="currentColor"/><circle cx="15" cy="13" r="0.6" fill="currentColor"/>',
  // 抖音：音符
  douyin:
    '<path d="M9.5 17.5a3.25 3.25 0 1 0 0 6.5 3.25 3.25 0 0 0 0-6.5Z" transform="translate(0 -3)"/><path d="M12.75 17.5V4.5c.6 2.4 2.3 4 4.75 4.3"/>',
  // 快手：摄像机
  kuaishou: '<rect x="2.5" y="6.5" width="13" height="11" rx="3.5"/><path d="M15.5 10.5 21 7v10l-5.5-3.5"/>',
  // 视频号：取景框 + 播放
  channels:
    '<rect x="3" y="5" width="18" height="14" rx="4"/><path d="M10.2 9.3v5.4l4.8-2.7Z" fill="currentColor" stroke="none"/>',
  // 公众号：对话气泡
  wechat:
    '<path d="M4 8.5A4.5 4.5 0 0 1 8.5 4h4A4.5 4.5 0 0 1 17 8.5v.5A4.5 4.5 0 0 1 12.5 13H11l-3 3v-3.5A4.5 4.5 0 0 1 4 9Z"/><path d="M15.5 14.5h1A3.5 3.5 0 0 1 20 18v.5a3.5 3.5 0 0 1-2 3.2V20l-2-1.5h-.5"/>',
  // YouTube
  youtube:
    '<rect x="2.5" y="5.5" width="19" height="13" rx="4"/><path d="M10.2 9.2v5.6l5-2.8Z" fill="currentColor" stroke="none"/>',
};
---

<section id="platforms">
  <div class="container">
    <SectionHead
      index="02 / 平台矩阵"
      title="全网同名，<span class='grad-text'>六大平台</span>"
      desc="同一套内容，适配每个平台的观看习惯。搜「鲲鹏Talk」都能找到我们。"
    />

    <div class="grid">
      {platforms.map((p, i) => (
        <a href={p.url} class="tile" data-reveal style={`--d:${i * 0.06}s`} target={p.url.startsWith('http') ? '_blank' : undefined} rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[p.key]} />
          <div class="meta">
            <strong>{p.name}</strong>
            <span>{p.handle}</span>
          </div>
          <em class="go">↗</em>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .tile {
    position: relative;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    transition:
      transform 0.35s cubic-bezier(0.2, 0.6, 0.2, 1),
      border-color 0.35s,
      background 0.35s;
  }

  .tile:hover {
    transform: translateY(-4px);
    border-color: rgba(31, 222, 194, 0.5);
    background: var(--panel-2);
  }

  svg {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    color: var(--muted);
    transition: color 0.35s;
  }

  .tile:hover svg {
    color: var(--cyan);
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .meta strong {
    font-size: 17px;
    font-weight: 700;
  }

  .meta span {
    font-size: 13px;
    color: var(--faint);
  }

  .go {
    position: absolute;
    top: 20px;
    right: 22px;
    font-style: normal;
    color: var(--faint);
    transition:
      color 0.3s,
      transform 0.3s;
  }

  .tile:hover .go {
    color: var(--cyan);
    transform: translate(3px, -3px);
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
