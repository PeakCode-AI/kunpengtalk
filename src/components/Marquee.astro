---
import { marqueeWords } from '../data/site';

const row = [...marqueeWords, ...marqueeWords];
---

<div class="marquee" aria-hidden="true">
  <div class="track">
    {row.map((w) => (
      <span class="word">{w}<i class="dot"></i></span>
    ))}
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    border-block: 1px solid var(--line);
    padding: 22px 0;
    background: rgba(255, 255, 255, 0.015);
  }

  .track {
    display: flex;
    width: max-content;
    animation: scroll 36s linear infinite;
  }

  .word {
    display: inline-flex;
    align-items: center;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--faint);
    white-space: nowrap;
  }

  .word:nth-child(odd) {
    color: rgba(148, 163, 184, 0.55);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    margin: 0 28px;
    background: var(--grad);
    opacity: 0.7;
  }

  @keyframes scroll {
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
  }
</style>
