---
import { membership as m } from '../data/site';

interface Props {
  /** 紧凑横幅模式（首页用） */
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

{compact ? (
  <section class="mship-compact" id="membership">
    <div class="container">
      <div class="band" data-reveal>
        <span class="crown" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 8l4.5 3L12 5l4.5 6L21 8l-1.5 10h-15L3 8Z"/></svg>
        </span>
        <div class="band-text">
          <strong>{m.name}</strong>
          <span>群内答疑咨询 · 课程与工具全场 5 折</span>
        </div>
        <span class="band-price"><s>{m.originalPrice}</s>{m.price}<em class="band-promo">{m.promoTag}</em></span>
        <a href="/services#membership" class="btn btn-primary band-cta">查看权益 ↗</a>
      </div>
    </div>
  </section>
) : (
  <section class="mship" id="membership">
    <div class="container">
      <div class="card" data-reveal>
        <span class="wm" aria-hidden="true">VIP</span>

        <div class="left">
          <p class="eyebrow">MEMBERSHIP · 付费会员群</p>
          <h2>{m.name}</h2>
          <p class="desc">{m.desc}</p>

          <ul class="benefits">
            {m.benefits.map((b) => (
              <li>
                <span class="check" aria-hidden="true">✓</span>
                <div>
                  <strong>{b.title}</strong>
                  <p>{b.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <div class="right">
          <div class="price-box">
            <span class="label">会员费</span>
            <div class="price-row">
              <strong class="price">{m.price}</strong>
              <s class="orig">{m.originalPrice}</s>
              <span class="promo">{m.promoTag}</span>
            </div>

            <ul class="math">
              {m.math.map((row) => (
                <li>
                  <span>{row.label}</span>
                  <span class="vals">
                    <s>{row.before}</s>
                    <em>{row.after}</em>
                  </span>
                </li>
              ))}
            </ul>

            <p class="payoff">一门课就省一半，会员费轻松回本。</p>

            <button class="btn btn-primary cta" data-open-wechat>{m.cta} ↗</button>
            <p class="cta-note">{m.ctaNote}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<style>
  /* ============ 完整版 ============ */
  .mship .card {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(36px, 5vw, 72px);
    padding: clamp(36px, 5vw, 64px);
    border-radius: calc(var(--radius) + 8px);
    border: 1px solid transparent;
    background:
      linear-gradient(165deg, #0d1320 0%, #0a0f19 60%, #0c1420 100%) padding-box,
      var(--grad) border-box;
    box-shadow:
      0 40px 100px rgba(46, 139, 255, 0.14),
      inset 0 0 60px rgba(31, 222, 194, 0.04);
    overflow: hidden;
  }

  .mship .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(600px 300px at 85% 0%, rgba(46, 139, 255, 0.12), transparent 65%);
    pointer-events: none;
  }

  .wm {
    position: absolute;
    right: 3%;
    bottom: -6%;
    font-size: clamp(120px, 16vw, 240px);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(148, 163, 184, 0.08);
    pointer-events: none;
    user-select: none;
  }

  .left .eyebrow {
    margin-bottom: 18px;
  }

  h2 {
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 14px;
  }

  .left > .desc {
    color: var(--muted);
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.9;
    margin-bottom: 34px;
  }

  .benefits {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .benefits li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .check {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: #04121a;
    background: var(--grad);
    margin-top: 2px;
  }

  .benefits strong {
    font-size: 16px;
  }

  .benefits p {
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
    line-height: 1.7;
  }

  /* 右侧价格盒 */
  .price-box {
    position: relative;
    padding: clamp(26px, 3vw, 36px);
    border-radius: calc(var(--radius) + 4px);
    background: rgba(5, 7, 12, 0.65);
    border: 1px solid var(--line-strong);
    backdrop-filter: blur(8px);
    text-align: center;
  }

  .label {
    font-size: 13px;
    letter-spacing: 0.18em;
    color: var(--faint);
  }

  .price-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 12px;
    margin: 6px 0 22px;
  }

  .price {
    font-size: clamp(56px, 6vw, 84px);
    font-weight: 700;
    line-height: 1.1;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .orig {
    font-size: 22px;
    color: var(--faint);
  }

  .promo {
    align-self: center;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #1a0a0a;
    background: linear-gradient(115deg, #ffb03a, #ff5f6d);
    border-radius: 999px;
    padding: 4px 12px;
    box-shadow: 0 6px 20px rgba(255, 95, 109, 0.35);
  }

  .math {
    text-align: left;
    border-top: 1px solid var(--line);
  }

  .math li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.08);
    font-size: 14px;
  }

  .math .vals {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-shrink: 0;
  }

  .math s {
    color: var(--faint);
    font-size: 13px;
  }

  .math em {
    font-style: normal;
    font-weight: 700;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .payoff {
    margin: 16px 0 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
  }

  .cta {
    width: 100%;
    justify-content: center;
    font-size: 16px;
    padding: 17px 30px;
  }

  .cta-note {
    margin-top: 12px;
    font-size: 12px;
    color: var(--faint);
  }

  /* ============ 紧凑横幅 ============ */
  .mship-compact {
    padding: 0;
  }

  .band {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2.5vw, 28px);
    flex-wrap: wrap;
    padding: 22px clamp(22px, 3vw, 36px);
    border-radius: calc(var(--radius) + 6px);
    border: 1px solid transparent;
    background:
      linear-gradient(var(--panel-2), var(--panel-2)) padding-box,
      var(--grad) border-box;
    box-shadow: 0 20px 60px rgba(46, 139, 255, 0.12);
  }

  .crown {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #04121a;
    background: var(--grad);
  }

  .crown svg {
    width: 24px;
    height: 24px;
  }

  .band-text {
    flex: 1;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .band-text strong {
    font-size: 17px;
  }

  .band-text span {
    font-size: 13px;
    color: var(--muted);
  }

  .band-price {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-size: 30px;
    font-weight: 700;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .band-price s {
    font-size: 16px;
    color: var(--faint);
    -webkit-text-fill-color: var(--faint);
  }

  .band-promo {
    align-self: center;
    font-style: normal;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #1a0a0a;
    -webkit-text-fill-color: #1a0a0a;
    background: linear-gradient(115deg, #ffb03a, #ff5f6d);
    border-radius: 999px;
    padding: 3px 10px;
  }

  .band-cta {
    padding: 12px 24px;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .mship .card {
      grid-template-columns: 1fr;
    }
  }
</style>
