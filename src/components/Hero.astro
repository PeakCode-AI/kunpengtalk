---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.png';
import { site, platforms, credentials } from '../data/site';

const stats = [
  { num: '6', label: '内容发布平台' },
  { num: '5', label: '深度内容专栏' },
  { num: '2', label: '上架产品' },
  { num: '6', label: '开源项目' },
];
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <div class="glow glow-blue"></div>
    <div class="glow glow-cyan"></div>
    <div class="grid-lines"></div>
    <span class="watermark">KUNPENG</span>
  </div>

  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow" data-reveal>鲲鹏TALK · AI 自媒体工作室</p>
      <h1 data-reveal style="--d:.1s">
        把前沿 <span class="grad-text">AI</span>，<br />讲成人话。
      </h1>
      <ul class="hero-credentials" data-reveal style="--d:.2s">
        {credentials.map((c) => (
          <li>
            <span class="tick" aria-hidden="true">✓</span>
            <span><strong>{c.name}</strong>{c.role}</span>
          </li>
        ))}
      </ul>
      <p class="sub" data-reveal style="--d:.3s">
        AI 大模型测评 / 本地部署 / Agent / Vibe Coding / 企业落地实践<br />
        全网同名 <strong>@鲲鹏Talk</strong>，六大平台同步更新。
      </p>
      <div class="hero-cta" data-reveal style="--d:.4s">
        <a href="#platforms" class="btn btn-primary">关注我们 ↗</a>
        <a href="#contact" class="btn btn-ghost">商务合作</a>
      </div>
      <ul class="hero-platforms" data-reveal style="--d:.5s">
        {platforms.map((p) => <li>{p.name}</li>)}
      </ul>
    </div>

    <div class="hero-visual" data-reveal style="--d:.25s">
      <div class="avatar-ring">
        <Image src={avatar} alt="鲲鹏Talk IP 形象" width={560} format="webp" class="avatar" loading="eager" />
      </div>
      <span class="chip c1">FDE</span>
      <span class="chip c2">大模型测评</span>
      <span class="chip c3">OPC</span>
      <span class="chip c4">Vibe Coding</span>
      <span class="chip c5">AI咨询</span>
      <span class="chip c6">Agent</span>
      <span class="chip c7">媒体合作</span>
    </div>
  </div>

  <div class="container">
    <dl class="stats" data-reveal style="--d:.45s">
      {stats.map((s) => (
        <div class="stat">
          <dt>{s.label}</dt>
          <dd>{s.num}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-h) + clamp(48px, 8vw, 96px));
    padding-bottom: clamp(56px, 7vw, 96px);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* ---- 背景 ---- */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.5;
  }

  .glow-blue {
    width: 44vw;
    height: 44vw;
    background: rgba(46, 139, 255, 0.22);
    top: -12vw;
    left: -10vw;
  }

  .glow-cyan {
    width: 36vw;
    height: 36vw;
    background: rgba(31, 222, 194, 0.14);
    bottom: -8vw;
    right: -6vw;
  }

  .grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 30%, transparent 75%);
  }

  .watermark {
    position: absolute;
    top: 8%;
    left: 50%;
    transform: translateX(-50%);
    font-size: clamp(90px, 17vw, 260px);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(148, 163, 184, 0.09);
    white-space: nowrap;
    user-select: none;
  }

  /* ---- 内容 ---- */
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    align-items: center;
    gap: 48px;
  }

  h1 {
    font-size: clamp(44px, 7.5vw, 96px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 26px 0 24px;
  }

  .sub {
    color: var(--muted);
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.9;
  }

  .sub strong {
    color: var(--fg);
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .hero-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 36px;
  }

  .hero-platforms li {
    font-size: 13px;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 14px;
    transition:
      color 0.25s,
      border-color 0.25s;
  }

  .hero-platforms li:hover {
    color: var(--cyan);
    border-color: var(--cyan);
  }

  /* ---- 视觉 ---- */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .avatar-ring {
    position: relative;
    width: min(340px, 30vw);
    aspect-ratio: 1;
    border-radius: 50%;
    padding: 10px;
    background: linear-gradient(160deg, rgba(46, 139, 255, 0.35), rgba(31, 222, 194, 0.15) 60%, transparent);
    box-shadow:
      0 0 80px rgba(46, 139, 255, 0.25),
      inset 0 0 40px rgba(31, 222, 194, 0.08);
    animation: float 7s ease-in-out infinite;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .chip {
    position: absolute;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 9px 18px;
    border-radius: 999px;
    background: rgba(12, 17, 27, 0.85);
    border: 1px solid var(--line-strong);
    backdrop-filter: blur(8px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    animation: float 6s ease-in-out infinite;
    white-space: nowrap;
  }

  /* 7 枚标签环绕头像（顺时针） */
  .c1 { top: 2%; left: -2%; color: var(--blue); animation-delay: 0.4s; }        /* FDE */
  .c2 { top: 12%; right: -4%; color: var(--cyan); animation-delay: 0.8s; }      /* 大模型测评 */
  .c3 { top: 44%; right: -14%; color: var(--blue); animation-delay: 1.2s; }     /* OPC */
  .c4 { bottom: 6%; right: 6%; color: var(--fg); animation-delay: 1.6s; }       /* Vibe Coding */
  .c5 { bottom: 2%; left: 6%; color: var(--cyan); animation-delay: 2s; }        /* AI咨询 */
  .c6 { bottom: 30%; left: -8%; color: var(--blue); animation-delay: 2.4s; }    /* Agent */
  .c7 { top: 40%; left: -14%; color: var(--fg); animation-delay: 2.8s; }        /* 媒体合作 */

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  .hero-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 26px;
  }

  .hero-credentials li {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 14px;
    color: var(--muted);
    border: 1px solid var(--line-strong);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 999px;
    padding: 8px 16px 8px 9px;
    transition:
      border-color 0.3s,
      transform 0.3s;
  }

  .hero-credentials li:hover {
    border-color: rgba(31, 222, 194, 0.5);
    transform: translateY(-2px);
  }

  .hero-credentials .tick {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: #04121a;
    background: var(--grad);
    flex-shrink: 0;
  }

  .hero-credentials strong {
    color: var(--fg);
    font-weight: 600;
    margin-right: 3px;
  }

  /* ---- 数据条 ---- */
  .stats {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: clamp(56px, 8vw, 96px);
    padding-top: 36px;
    border-top: 1px solid var(--line);
  }

  .stat dt {
    order: 2;
    font-size: 13px;
    color: var(--faint);
    letter-spacing: 0.08em;
    margin-top: 6px;
  }

  .stat dd {
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 700;
    line-height: 1;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  /* ---- 响应式 ---- */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 64px;
    }

    .hero-visual {
      order: -1;
    }

    .avatar-ring {
      width: min(260px, 60vw);
    }

    .chip {
      font-size: 11px;
      padding: 7px 13px;
    }

    .c1 { left: 0; }
    .c2 { right: 0; }
    .c3 { right: -4%; }
    .c5 { left: 2%; }
    .c6 { left: -2%; }
    .c7 { left: -4%; }
  }

  @media (max-width: 640px) {
    .stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-ring,
    .chip {
      animation: none;
    }
  }
</style>
