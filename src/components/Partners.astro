---
import { partners } from '../data/site';
---

<section class="partners" aria-label="合作品牌">
  <div class="container">
    <div class="head" data-reveal>
      <p class="eyebrow">合作品牌 · PARTNERS</p>
      <p class="note">内容、课程与企业服务合作（排名不分先后）</p>
    </div>
    <ul class="row" data-reveal style="--d:.1s">
      {partners.map((p) => (
        <li>
          <a href={p.url} target="_blank" rel="noopener" title={p.name}>
            {p.mode === 'text' ? (
              <span class="logo-text">{p.text}</span>
            ) : (
              <img
                src={p.logo}
                alt={p.name}
                loading="lazy"
                class={p.mode === 'white' ? 'logo-white' : 'logo-icon'}
              />
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .partners {
    padding: clamp(40px, 5vw, 64px) 0;
    border-bottom: 1px solid var(--line);
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .note {
    font-size: 13px;
    color: var(--faint);
    letter-spacing: 0.04em;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 30px clamp(32px, 4.5vw, 56px);
    margin-top: 34px;
  }

  .row a {
    display: flex;
    align-items: center;
  }

  /* 文字标 + 白标统一透明度节奏 */
  .logo-white,
  .logo-text {
    opacity: 0.5;
    transition:
      opacity 0.3s,
      transform 0.3s;
  }

  .logo-white {
    height: clamp(24px, 2.4vw, 32px);
    width: auto;
    max-width: 160px;
    object-fit: contain;
    /* 统一转为白色单色，保证深色背景上的视觉一致性 */
    filter: brightness(0) invert(1);
  }

  .logo-icon {
    height: clamp(28px, 2.8vw, 36px);
    width: clamp(28px, 2.8vw, 36px);
    border-radius: 24%;
    object-fit: cover;
    transition:
      transform 0.3s,
      box-shadow 0.3s;
  }

  .logo-text {
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--fg);
    white-space: nowrap;
  }

  .row a:hover .logo-white,
  .row a:hover .logo-text {
    opacity: 1;
    transform: translateY(-2px);
  }

  .row a:hover .logo-icon {
    transform: translateY(-2px) scale(1.06);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
  }
</style>
