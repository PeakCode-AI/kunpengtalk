---
import SectionHead from './SectionHead.astro';
import { services, site } from '../data/site';
---

<section id="services">
  <div class="container">
    <SectionHead
      index="01 / 企业服务"
      title="培训与咨询"
      desc="不讲概念，只做能落地的训练和咨询。按小时计费，效果当场可见。"
    />

    <div class="grid">
      {services.map((s, i) => (
        <article class={`plan ${s.highlight ? 'highlight' : ''}`} data-reveal style={`--d:${i * 0.1}s`}>
          <span class="en">{s.en}</span>
          <h3>{s.name}</h3>
          <div class="price">
            <strong>{s.price}</strong>
            <span>{s.unit}</span>
          </div>
          <p class="desc">{s.desc}</p>
          <ul class="features">
            {s.features.map((f) => <li>{f}</li>)}
          </ul>
          <a href={`mailto:${site.email}?subject=${encodeURIComponent(s.name + '预约 — ' + site.name)}`} class={`btn ${s.highlight ? 'btn-primary' : 'btn-ghost'}`}>
            {s.cta} ↗
          </a>
        </article>
      ))}
    </div>

    <p class="note" data-reveal>企业年度顾问、定制开发与其他形式的合作，请直接联系商务详谈。</p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .plan {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 44px;
    border: 1px solid var(--line);
    border-radius: calc(var(--radius) + 6px);
    background: var(--panel);
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1),
      border-color 0.4s;
  }

  .plan:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
  }

  .plan.highlight {
    border-color: transparent;
    background:
      linear-gradient(var(--panel-2), var(--panel-2)) padding-box,
      var(--grad) border-box;
  }

  .plan.highlight::after {
    content: '热门';
    position: absolute;
    top: 24px;
    right: 24px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #04121a;
    background: var(--grad);
    border-radius: 999px;
    padding: 5px 14px;
  }

  .en {
    font-size: 12px;
    letter-spacing: 0.24em;
    color: var(--faint);
  }

  h3 {
    font-size: clamp(24px, 2.6vw, 32px);
    font-weight: 700;
    margin: 14px 0 22px;
  }

  .price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--line);
  }

  .price strong {
    font-size: clamp(40px, 4.5vw, 56px);
    font-weight: 700;
    line-height: 1;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .price span {
    color: var(--faint);
    font-size: 15px;
  }

  .desc {
    color: var(--muted);
    font-size: 15px;
    margin: 22px 0;
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 36px;
  }

  .features li {
    position: relative;
    padding-left: 26px;
    font-size: 15px;
    color: var(--fg);
  }

  .features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .plan .btn {
    margin-top: auto;
    align-self: flex-start;
  }

  .note {
    margin-top: 36px;
    text-align: center;
    color: var(--faint);
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .plan {
      padding: 32px;
    }
  }
</style>
