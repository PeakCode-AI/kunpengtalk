---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import SectionHead from '../components/SectionHead.astro';
import { videoDeals, writingDeals, platforms } from '../data/site';
---

<Layout title="视频定制 — 鲲鹏Talk" description="鲲鹏Talk 商单合作：定制视频、植入视频、公众号约稿、小红书/公众号图文，全部全平台投放。">
  <Nav />
  <main>
    <section class="page-hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="glow"></div>
        <span class="watermark">SPONSORED</span>
      </div>
      <div class="container">
        <p class="eyebrow" data-reveal>SPONSORED · 视频定制</p>
        <h1 data-reveal style="--d:.1s">
          让好内容，<br /><span class="grad-text">为你的品牌说话。</span>
        </h1>
        <p class="sub" data-reveal style="--d:.2s">
          商单合作灵活，{platforms.map((p) => p.name).join(' · ')} 全平台投放。<br />
          合作流程简单，确认需求后一周内出片。
        </p>
      </div>
    </section>

    <section id="video-deals">
      <div class="container">
        <SectionHead
          index="01 / 视频合作"
          title="视频商单"
          desc="均含全平台投放。"
        />

        <div class="grid">
          {videoDeals.map((d, i) => (
            <article class="plan" data-reveal style={`--d:${i * 0.1}s`}>
              <span class="en">{d.en}</span>
              <h3>{d.name}</h3>
              <div class="price">
                <strong>{d.price}</strong>
                <s>{d.original}</s>
              </div>
              <span class="promo">{d.promo}</span>
              <p class="desc">{d.desc}</p>
              <ul class="points">
                {d.points.map((pt) => <li>{pt}</li>)}
              </ul>
              <button class="btn btn-primary" data-open-wechat>微信约单 ↗</button>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="writing-deals" class="writing">
      <div class="container">
        <SectionHead
          index="02 / 文字与图文"
          title="约稿与图文"
          desc="深度文字稿和图文单发，按需合作。"
        />

        <div class="grid">
          {writingDeals.map((d, i) => (
            <article class="plan plain" data-reveal style={`--d:${i * 0.1}s`}>
              <h3>{d.name}</h3>
              <div class="price">
                <strong>{d.price}</strong>
                <span class="unit">{d.unit}</span>
              </div>
              <p class="desc">{d.desc}</p>
              <ul class="points">
                {d.points.map((pt) => <li>{pt}</li>)}
              </ul>
              <button class="btn btn-ghost" data-open-wechat>微信约单 ↗</button>
            </article>
          ))}
        </div>

        <p class="note" data-reveal>
          以上合作均含全平台投放；排期、批量打包与其他合作形式，请添加鲲鹏助理微信详谈。
        </p>
      </div>
    </section>

    <Contact />
  </main>
  <Footer />
</Layout>

<style>
  main {
    padding-top: var(--nav-h);
  }

  /* ---- 页头 ---- */
  .page-hero {
    position: relative;
    padding: clamp(80px, 10vw, 130px) 0 clamp(40px, 5vw, 64px);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    width: 40vw;
    height: 40vw;
    border-radius: 50%;
    filter: blur(120px);
    background: rgba(46, 139, 255, 0.15);
    top: -18vw;
    right: -10vw;
  }

  .watermark {
    position: absolute;
    top: 30%;
    right: -2%;
    font-size: clamp(70px, 11vw, 170px);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(148, 163, 184, 0.09);
    white-space: nowrap;
    user-select: none;
  }

  h1 {
    font-size: clamp(40px, 6.5vw, 80px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 26px 0 24px;
  }

  .sub {
    color: var(--muted);
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.9;
  }

  /* ---- 报价卡 ---- */
  .writing {
    padding-top: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .plan {
    display: flex;
    flex-direction: column;
    padding: 40px;
    border-radius: calc(var(--radius) + 6px);
    border: 1px solid transparent;
    background:
      linear-gradient(var(--panel-2), var(--panel-2)) padding-box,
      var(--grad) border-box;
    transition: transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .plan.plain {
    border: 1px solid var(--line);
    background: var(--panel);
  }

  .plan:hover {
    transform: translateY(-6px);
  }

  .en {
    font-size: 12px;
    letter-spacing: 0.24em;
    color: var(--faint);
  }

  h3 {
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 700;
    margin: 12px 0 20px;
  }

  .price {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .price strong {
    font-size: clamp(38px, 4.2vw, 52px);
    font-weight: 700;
    line-height: 1;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .price s {
    font-size: 20px;
    color: var(--faint);
  }

  .price .unit {
    font-size: 15px;
    color: var(--faint);
  }

  .promo {
    display: inline-block;
    align-self: flex-start;
    margin-top: 12px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #1a0a0a;
    background: linear-gradient(115deg, #ffb03a, #ff5f6d);
    border-radius: 999px;
    padding: 5px 14px;
  }

  .desc {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.8;
    margin: 20px 0;
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .points {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 30px;
  }

  .points li {
    position: relative;
    padding-left: 24px;
    font-size: 14px;
  }

  .points li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .plan .btn {
    margin-top: auto;
    align-self: flex-start;
  }

  .note {
    margin-top: 36px;
    text-align: center;
    color: var(--faint);
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .plan {
      padding: 30px;
    }
  }
</style>
