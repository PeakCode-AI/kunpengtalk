---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ossProjects, ossStats } from '../data/site';
---

<Layout title="开源项目 — 鲲鹏Talk" description="鲲鹏Talk 的开源项目：Prompt-Tools、Claude Skills 金融套件、多智能体框架、AI 法律工作台等，全部免费开源。">
  <Nav />
  <main>
    <section class="page-hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="glow"></div>
        <span class="watermark">OPEN&nbsp;SOURCE</span>
      </div>
      <div class="container">
        <p class="eyebrow" data-reveal>OPEN SOURCE · 开源项目</p>
        <h1 data-reveal style="--d:.1s">
          写的工具，<br /><span class="grad-text">全都开源。</span>
        </h1>
        <p class="sub" data-reveal style="--d:.2s">
          从 Prompt 管理到多智能体框架，从 A 股金融到法律工作台——<br />
          视频里讲的每一行代码，你都能在 GitHub 上拿到。
        </p>
        <div class="hero-cta" data-reveal style="--d:.3s">
          <a href={ossStats.github} class="btn btn-primary" target="_blank" rel="noopener">
            GitHub 主页 ↗
          </a>
          <span class="total">
            <strong>{ossStats.projects}</strong> 个开源项目 ·
            <strong>{(ossStats.stars / 1000).toFixed(1)}k+</strong> 社区 Star
          </span>
        </div>
      </div>
    </section>

    <section class="projects">
      <div class="container">
        <div class="grid">
          {ossProjects.map((p, i) => (
            <a href={p.url} target="_blank" rel="noopener" class="card" data-reveal style={`--d:${i * 0.07}s`}>
              <div class="top">
                <svg class="gh" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
                </svg>
                <span class="arrow" aria-hidden="true">↗</span>
              </div>
              <h2>{p.name}</h2>
              <p class="desc">{p.desc}</p>
              <ul class="tags">
                {p.tags.map((t) => <li>{t}</li>)}
              </ul>
              <div class="meta">
                <span class="lang">
                  <i style={`background:${p.langColor}`}></i>{p.lang}
                </span>
                <span class="star">★ {p.stars}</span>
                <span class="fork">⑂ {p.forks}</span>
              </div>
            </a>
          ))}
        </div>

        <p class="note" data-reveal>
          以上项目均可自由 Fork 与商用（遵循各自仓库 License）。欢迎 Star、提 Issue，更欢迎 PR。
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  main {
    padding-top: var(--nav-h);
  }

  /* ---- 页头 ---- */
  .page-hero {
    position: relative;
    padding: clamp(80px, 10vw, 130px) 0 clamp(48px, 6vw, 80px);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    width: 40vw;
    height: 40vw;
    border-radius: 50%;
    filter: blur(120px);
    background: rgba(46, 139, 255, 0.16);
    top: -18vw;
    right: -10vw;
  }

  .watermark {
    position: absolute;
    top: 30%;
    right: -2%;
    font-size: clamp(70px, 11vw, 170px);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(148, 163, 184, 0.09);
    white-space: nowrap;
    user-select: none;
  }

  h1 {
    font-size: clamp(40px, 6.5vw, 80px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 26px 0 24px;
  }

  .sub {
    color: var(--muted);
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.9;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .total {
    color: var(--muted);
    font-size: 15px;
  }

  .total strong {
    color: var(--fg);
    font-size: 18px;
  }

  /* ---- 项目卡片 ---- */
  .projects {
    padding-top: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 32px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(170deg, var(--panel) 0%, rgba(12, 17, 27, 0.4) 100%);
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1),
      border-color 0.4s;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(420px 220px at 85% -10%, rgba(31, 222, 194, 0.1), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
  }

  .card:hover::before {
    opacity: 1;
  }

  .top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 22px;
  }

  .gh {
    width: 26px;
    height: 26px;
    color: var(--muted);
    transition: color 0.3s;
  }

  .card:hover .gh {
    color: var(--fg);
  }

  .arrow {
    font-size: 20px;
    color: var(--cyan);
    opacity: 0;
    transform: translate(-8px, 8px);
    transition:
      opacity 0.35s,
      transform 0.35s;
  }

  .card:hover .arrow {
    opacity: 1;
    transform: none;
  }

  h2 {
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    word-break: break-all;
  }

  .desc {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .tags li {
    font-size: 12px;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
  }

  .meta {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    font-size: 13px;
    color: var(--faint);
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .lang i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .star {
    color: #f0b429;
  }

  .note {
    margin-top: 40px;
    text-align: center;
    color: var(--faint);
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
